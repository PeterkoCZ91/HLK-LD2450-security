#ifndef SECRETS_H
#define SECRETS_H

// =========================================================================
// Copy this file to `secrets.h` and fill in your own values.
// `secrets.h` is gitignored — never commit real credentials.
// =========================================================================

// WiFi Configuration (fallback when WiFiManager AP not used)
#define WIFI_SSID_DEFAULT "YourSSID"
#define WIFI_PASS_DEFAULT "YourPassword"

// MQTT Broker
#define MQTT_SERVER_DEFAULT "192.168.1.100"
#define MQTT_PORT_DEFAULT   1883
#define MQTT_USER_DEFAULT   "mqtt_user"
#define MQTT_PASS_DEFAULT   "mqtt_pass"

// MQTTS (TLS) — used when build flag -D MQTTS_ENABLED is set AND port is 8883
#define MQTTS_PORT 8883

// MQTT Server CA Certificate (paste your self-signed or commercial CA here)
static const char* mqtt_server_ca = R"EOF(-----BEGIN CERTIFICATE-----
...INSERT YOUR CA CERT HERE...
-----END CERTIFICATE-----)EOF";

// Web Admin (default credentials — change in GUI Network tab)
#define WEB_ADMIN_USER_DEFAULT "admin"
#define WEB_ADMIN_PASS_DEFAULT "admin"

// Telegram Bot (leave empty strings to disable Telegram by default;
// users still enable + configure in GUI Network tab)
#define TELEGRAM_TOKEN_DEFAULT ""
#define TELEGRAM_CHAT_ID_DEFAULT ""

// BLE Security (passkey for emergency-disarm BLE characteristic)
#define BLE_PASSKEY_DEFAULT 123456

#endif
